# Basemap PMTiles archive served at runtime via HTTP range requests.
# Local development defaults to the Italy extract in studio/public/italia.pmtiles
# (served by Vite at /italia.pmtiles). Leave unset to use that default.
# In production, point this at the self-hosted Italy extract on Cloudflare R2, e.g.:
#   VITE_TILES_URL=https://tiles.zornade.com/italia.pmtiles
# VITE_TILES_URL=/italia.pmtiles

# --- Internal access gate (client-side, interim) -----------------------------
# Username (not secret) and the SHA-256 hash of the password. Set these in a
# gitignored .env.local. The plaintext password is NEVER stored anywhere.
# Generate the hash by typing your password yourself in a terminal:
#   printf '%s' 'LA_TUA_PASSWORD' | sha256sum
# Then copy the 64-char hex digest below.
# VITE_STUDIO_USER=redazione
# VITE_STUDIO_PASS_SHA256=
