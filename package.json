{
  "name": "zornade-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zornade Studio - editor open source per mappe e visualizzazioni dati editoriali",
  "license": "AGPL-3.0-or-later",
  "author": "Zornade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zornade/zornade-studio.git"
  },
  "homepage": "https://studio.zornade.com",
  "bugs": {
    "url": "https://github.com/zornade/zornade-studio/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "probe:portals": "vite-node scripts/probe-portals.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@maplibre/maplibre-gl-style-spec": "^23.3.0",
    "@observablehq/plot": "^0.6.17",
    "@protomaps/basemaps": "^5.6.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tmcw/togeojson": "^7.1.2",
    "fflate": "^0.8.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.3.0",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shpjs": "^6.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.6"
  }
}
